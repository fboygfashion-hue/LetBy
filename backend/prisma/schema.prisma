generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// USERS
model User {
  id                String               @id @default(uuid())
  telegramId        String               @unique
  username          String?
  fullName          String?
  phoneNumber       String?
  avatarUrl         String?
  listings          Listing[]            @relation("UserListings")
  reviews           Review[]             @relation("BuyerReviews")
  sellerReviews     Review[]             @relation("SellerReviews")
  verification      VerificationRequest?
  sellerBadge       SellerBadge?
  notifications     Notification[]
  isAdmin           Boolean              @default(false)
  phoneVerified     Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

// PRODUCT LISTING
model Listing {
  id          String     @id @default(uuid())
  title       String
  description String
  images      String[]
  price       Int
  category    Category   @relation(fields: [categoryId], references: [id])
  categoryId  String
  seller      User       @relation("UserListings", fields: [sellerId], references: [id])
  sellerId    String
  status      String     @default("active")
  reviews     Review[]   @relation("ListingReviews")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// CATEGORY
model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  listings Listing[]
}

// FEEDBACK & TRUST
model Review {
  id         String   @id @default(uuid())
  rating     Int
  comment    String?
  buyer      User     @relation("BuyerReviews", fields: [buyerId], references: [id])
  buyerId    String
  seller     User     @relation("SellerReviews", fields: [sellerId], references: [id])
  sellerId   String
  listing    Listing  @relation("ListingReviews", fields: [listingId], references: [id])
  listingId  String
  createdAt  DateTime @default(now())
}

// KYC/VERIFICATION
model VerificationRequest {
  id            String   @id @default(uuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String   @unique
  nationalIdUrl String?
  phoneVerified Boolean  @default(false)
  status        String   @default("pending")
  adminComment  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// SELLER BADGING
model SellerBadge {
  id      String @id @default(uuid())
  user    User   @relation(fields: [userId], references: [id])
  userId  String @unique
  type    String // e.g. "VERIFIED"
  issuedAt DateTime @default(now())
}

// NOTIFICATIONS
model Notification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  type      String
  data      Json
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ADMIN & REPORTING
model Admin {
  id       String @id @default(uuid())
  user     User   @relation(fields: [userId], references: [id])
  userId   String @unique
}

model Report {
  id         String   @id @default(uuid())
  reporter   User     @relation(fields: [reporterId], references: [id])
  reporterId String
  listing    Listing  @relation(fields: [listingId], references: [id])
  listingId  String
  reason     String
  status     String   @default("open")
  createdAt  DateTime @default(now())
}
